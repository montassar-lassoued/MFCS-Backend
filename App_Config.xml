            <StorageSystem>
                <SRM id="SR01" pattern="GGGG-S-XXX-YY-ZZ">
                    <Rack>
                        <Side type="L">
                            <Range> <!-- so ist es aufgebaut, dass es bei Bedarf Blöcke (Range)
                        übersprungen werden können, z.B. falls diese Physisch nicht existieren-->
                                <X start="1" end="20"/>
                                <Y start="1" end="10"/>
                                <Depth count="2"/>
                                <Permission>Perm_A</Permission> <!-- Welche Loadunit-Kategorien dürfen hier rein -->
                            </Range>
                            <Range>
                                <X start="23" end="40"/>
                                <Y start="1" end="10"/>
                                <Depth count="2"/>
                                <Permission>Perm_B_C</Permission>
                            </Range>
                        </Side>
                        <Side type="R">
                            <Range>
                                <X start="1" end="30"/>
                                <Y start="1" end="10"/>
                                <Depth count="2"/>
                                <Permission>Perm_A_B</Permission>
                            </Range>
                            <Range>
                                <X start="30" end="40"/>
                                <Y start="1" end="10"/>
                                <Depth count="2"/>
                                <Permission>Perm_C</Permission>
                            </Range>
                        </Side>
                    </Rack>
                    <Forks> <!-- Gabel mit Ein-/Auslagern Points-->
                        <Fork name="LHD01*">
                            <EntryPoints>
                                <Entry>S350</Entry>
                            </EntryPoints>
                            <ExitPoins>
                                <Exit>S350</Exit>
                            </ExitPoins>
                        </Fork>
                    </Forks>
                </SRM>
                <SRM id="SR02" pattern="GGGG-S-XXX-YY-ZZ">
                    <Rack>
                        <Side type="L">
                            <Range> <!-- so ist es aufgebaut, dass es bei Bedarf Blöcke (Range)
                        übersprungen werden können, z.B. falls diese Physisch nicht existieren-->
                                <X start="1" end="20"/>
                                <Y start="1" end="10"/>
