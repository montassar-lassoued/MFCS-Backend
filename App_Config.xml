                                <Y start="1" end="10"/>
                                <Depth count="2"/>
                                <Permission>Perm_C</Permission>
                            </Range>
                        </Side>
                    </Rack>
                    <Forks> <!-- Gabel mit Ein-/Auslagern Points-->
                        <Fork name="LHD01*">
                            <EntryPoints>
                                <Entry>S350</Entry>
                            </EntryPoints>
                            <ExitPoins>
                                <Exit>S350</Exit>
                            </ExitPoins>
                        </Fork>
                    </Forks>
                </SRM>
            </StorageSystem>
            <Loadunit> <!-- Loadunit, Definitionen für die Kategorien -->
                <Categories>
                    <Categorie name="A" height="1300" width="3000" length="1000" minWeight="1000" maxWeight="5000" />
                    <Categorie name="B" height="1500" width="3000" length="1000" minWeight="1000" maxWeight="5000" />
                    <Categorie name="C" height="1300" width="3200" length="1500" minWeight="1000" maxWeight="5000" />
                </Categories>
                <Permissions> <!-- für die Fächer (beim Einlagern wichtig) -->
                  <Permission name="Perm_A"> <!-- erlaubt nur Categorie A -->
                        <Categorie>A</Categorie>
                    </Permission>
                    <Permission name="Perm_A_B"> <!-- erlaubt Categorie A & B -->
                        <Categorie>A</Categorie>
                        <Categorie>B</Categorie>
                    </Permission>
                    <Permission name="Perm_B_C"> <!-- erlaubt Categorie B & C -->
                        <Categorie>B</Categorie>
                        <Categorie>C</Categorie>
                    </Permission>
                    <Permission name="Perm_B_C"> <!-- erlaubt nur Categorie C -->
                        <Categorie>C</Categorie>
                    </Permission>
                </Permissions>
            </Loadunit>
